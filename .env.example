# Copy to .env.production on the VPS (never commit real secrets)
#   cp .env.example .env.production

SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_ROLE=
GROQ_API_KEY=
CARGO_LLM_PRIORITY=groq,openai,anthropic

NOTIFICATION_MODE=production
