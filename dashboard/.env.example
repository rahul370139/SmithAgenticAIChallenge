# Local dev — copy to .env.local (Vite proxy in vite.config.js handles /api and /ws)
# Leave VITE_API_URL empty so requests go to same origin (localhost:5173 → proxy → :8000)
VITE_API_URL=

# ── Vercel production (Pathwise-style HTTPS without backend TLS) ─────────────
# Do NOT set VITE_API_URL to http://IP:8001 — browsers block HTTPS→HTTP (mixed content).
# Instead: leave VITE_API_URL unset/empty and configure rewrites in vercel.json to proxy
# /api/* and /ws/* to your Hostinger backend (see dashboard/vercel.json).
#
# Update vercel.json destination if your VPS IP or port changes:
#   "destination": "http://YOUR_VPS_IP:8001/api/:path*"
