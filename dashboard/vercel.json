{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://2.24.74.235:8001/api/:path*"
    },
    {
      "source": "/ws/:path*",
      "destination": "http://2.24.74.235:8001/ws/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
